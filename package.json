{
  "name": "taskasaur",
  "version": "0.1.0",
  "description": "CSDB-backed cross-platform time tracking app built with React, Electron, and Capacitor.",
  "author": {
    "name": "Taskasaur Contributors",
    "email": "taskasaur@users.noreply.github.com"
  },
  "homepage": "https://taskasaur.net",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:web": "tsc -b && vite build",
    "build:macos": "npm run build:web && electron-builder --mac dmg zip --arm64",
    "build:windows": "npm run build:web && electron-builder --win nsis --x64",
    "build:linux": "npm run build:web && electron-builder --linux AppImage deb --x64",
    "prepare:ios": "npm run build:web && cap sync ios",
    "prepare:android": "npm run build:web && cap sync android",
    "build:ios": "npm run prepare:ios && xcodebuild -workspace ios/App/App.xcworkspace -scheme App -configuration Release -destination generic/platform=iOS -derivedDataPath release/ios CODE_SIGNING_ALLOWED=NO",
    "build:android": "npm run prepare:android && cd android && ./gradlew assembleRelease",
    "preview": "vite preview",
    "electron:dev": "vite dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:dir": "tsc -b && vite build && electron-builder --dir",
    "cap:sync": "cap sync",
    "cap:sync:ios": "cap sync ios",
    "cap:sync:android": "cap sync android",
    "cap:open:ios": "cap open ios",
    "cap:open:android": "cap open android"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@capacitor/android": "^7.6.8",
    "@capacitor/core": "^7.1.0",
    "@capacitor/ios": "^7.1.0",
    "@csdb/javascript": "file:../csvdatabase/csdb-javascript",
    "@csvdatabase/csdb": "file:../csvdatabase/csdb-javascript",
    "@fontsource-variable/geist": "^5.2.9",
    "@milkdown/crepe": "^7.21.2",
    "@monaco-editor/react": "^4.7.0",
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.0",
    "lexorank": "^1.0.5",
    "lucide-react": "^0.511.0",
    "monaco-editor": "^0.55.1",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-arborist": "^3.8.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "shadcn": "^4.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.42",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^7.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.3"
  },
  "build": {
    "appId": "com.taskasaur.app",
    "productName": "Taskasaur",
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "templates/**/*",
      "databases.csdb",
      "data/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "databases.csdb",
        "to": "databases.csdb"
      },
      {
        "from": "data",
        "to": "data"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    }
  }
}
